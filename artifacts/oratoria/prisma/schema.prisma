generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Upcoming club events. isPublished controls landing-page visibility.
model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  dateTime    DateTime
  place       String
  price       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  registrations Registration[]
}

// v1.0.1: phone made required; status default changed to "new";
//         @@unique([email, eventId]) prevents duplicate registrations
//         for the same person + event pair at the database level.
model Registration {
  id               String   @id @default(cuid())
  phone            String
  email            String
  eventId          String
  marketingConsent Boolean  @default(false)
  // Lifecycle: new → confirmed | cancelled
  status           String   @default("new")
  createdAt        DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id])

  @@unique([email, eventId])
}

// Email-only newsletter opt-in. Upsert keeps it idempotent.
model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

// Key/value store for editable landing-page copy (hero, about, etc.).
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  title     String
  body      String
  updatedAt DateTime @updatedAt
}

// FAQ items rendered in the FAQ section. sortOrder controls display order.
model FaqItem {
  id          String  @id @default(cuid())
  question    String
  answer      String
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
}

// Benefit cards rendered in the "Зачем приходить?" section.
// number is a display label (e.g. "01"). sortOrder controls card order.
model Benefit {
  id          String  @id @default(cuid())
  number      String
  title       String
  body        String
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
}

// Testimonial quotes rendered in the "Что говорят участники" section.
model Testimonial {
  id          String  @id @default(cuid())
  name        String
  role        String
  quote       String
  sortOrder   Int     @default(0)
  isPublished Boolean @default(true)
}
