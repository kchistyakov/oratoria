# База данных PostgreSQL (обязательно)
DATABASE_URL="postgresql://user:password@localhost:5432/oratoria"

# Администратор панели управления (обязательно)
# Панель доступна по адресу /panel
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="замените-на-надёжный-пароль"
# Произвольная случайная строка для подписи сессионного токена
ADMIN_SECRET="замените-на-случайную-строку-32+-символа"

# Окружение
NODE_ENV="development"
